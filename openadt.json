{
  "version": "1.3.1",
  "description": "Local bridge for SAP ADT traffic",
  "homepage": "https://github.com/abapify/openadt",
  "license": "Apache-2.0",
  "notes": "Requires Java 21 on PATH. `openadt mcp` also requires Bun (https://bun.sh). Optional: scoop bucket add java && scoop install openjdk21",
  "architecture": {
    "64bit": {
      "url": "https://github.com/abapify/openadt/releases/download/v1.3.1/openadt-1.3.1.zip",
      "hash": "4c831f5c741267fc15c6a64687ecf665afa71218b22b4dde74779549edf19073"
    }
  },
  "extract_dir": "openadt-1.3.1",
  "bin": "openadt.exe",
  "suggest": {
    "JDK 21": "java/openjdk21",
    "Bun (for openadt mcp)": "main/bun"
  },
  "post_install": [
    "& (Join-Path $dir 'bin\\scoop-post-install.ps1') -InstallDir $dir"
  ],
  "checkver": {
    "github": "abapify/openadt"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/abapify/openadt/releases/download/v$version/openadt-$version.zip"
      }
    },
    "hash": {
      "url": "$baseurl/openadt-$version.zip.sha256",
      "regex": "^(?<hash>[A-Fa-f0-9]{64})"
    },
    "extract_dir": "openadt-$version"
  }
}
