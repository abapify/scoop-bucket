{
  "version": "2.0.0",
  "description": "Local bridge for SAP ADT traffic",
  "homepage": "https://github.com/abapify/openadt",
  "license": "Apache-2.0",
  "notes": "Requires Java 21 on PATH. `openadt mcp` also requires Bun at runtime (https://bun.sh). MCP launcher is bundled as a single file.",
  "architecture": {
    "64bit": {
      "url": "https://github.com/abapify/openadt/releases/download/v2.0.0/openadt-2.0.0.zip",
      "hash": "9e6f9d49e9a1c896a5dc6f291b160074e6d72df4b8ac7c73984fa4a7d8a54430"
    }
  },
  "extract_dir": "openadt-2.0.0",
  "bin": "openadt.exe",
  "suggest": {
    "JDK 21": "java/openjdk21",
    "Bun (for openadt mcp)": "main/bun"
  },
  "post_install": [
    "& (Join-Path $dir 'bin\\scoop-post-install.ps1') -InstallDir $dir"
  ],
  "checkver": {
    "github": "abapify/openadt"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/abapify/openadt/releases/download/v$version/openadt-$version.zip"
      }
    },
    "hash": {
      "url": "$baseurl/openadt-$version.zip.sha256",
      "regex": "^(?<hash>[A-Fa-f0-9]{64})"
    },
    "extract_dir": "openadt-$version"
  }
}
